// SQLite for local dev. To move to Postgres: change provider, set DATABASE_URL,
// and convert the String role/status/type columns to native enums.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              Int       @id @default(autoincrement())
  firstName       String
  lastName        String
  email           String    @unique // stored lowercased
  pendingEmail    String? // requested new email, awaiting verification
  passwordHash    String
  role            String    @default("member") // "member" | "officer"
  graduationYear  Int? // class year, for reporting and rollover
  deactivatedAt   DateTime? // set when an officer removes a member; blocks login
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())

  signups         EventSignup[] @relation("UserSignups")
  markedSignups   EventSignup[] @relation("MarkedBy")
  createdEvents   Event[]       @relation("CreatedBy")
  approvedEvents  Event[]       @relation("ApprovedBy")
  invitesCreated  InviteToken[]
  authTokens      AuthToken[]
  sessions        Session[]
  hourReports     HourReport[]  @relation("ReportOwner")
  reviewedReports HourReport[]  @relation("ReportReviewer")
}

model Event {
  id           Int      @id @default(autoincrement())
  title        String
  description  String?
  location     String?
  status       String   @default("active") // "active" | "completed" | "pending_approval" | "cancelled"
  createdById  Int
  approvedById Int?
  createdAt    DateTime @default(now())

  createdBy  User       @relation("CreatedBy", fields: [createdById], references: [id])
  approvedBy User?      @relation("ApprovedBy", fields: [approvedById], references: [id])
  timeslots  Timeslot[]

  @@index([status])
}

model Timeslot {
  id          Int       @id @default(autoincrement())
  eventId     Int
  date        DateTime // UTC midnight; date-only semantics
  startTime   String // "HH:MM" 24h, display only
  endTime     String // "HH:MM" 24h, display only
  hoursValue  Float     @default(1.0)
  quota       Int // volunteers needed (confirmed cap)
  completedAt DateTime? // set when an officer takes attendance for this slot

  event   Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  signups EventSignup[]

  @@index([eventId])
  @@index([date])
}

model EventSignup {
  id         Int      @id @default(autoincrement())
  timeslotId Int
  userId     Int
  status     String   @default("confirmed") // "confirmed" | "waitlisted"
  signedUpAt DateTime @default(now())
  attended   Boolean  @default(false)
  markedById Int?

  timeslot Timeslot @relation(fields: [timeslotId], references: [id], onDelete: Cascade)
  user     User     @relation("UserSignups", fields: [userId], references: [id])
  markedBy User?    @relation("MarkedBy", fields: [markedById], references: [id])

  @@unique([timeslotId, userId])
}

model HourReport {
  id             Int       @id @default(autoincrement())
  userId         Int
  description    String
  notes          String?
  date           DateTime // UTC midnight; the activity date
  hoursRequested Float
  status         String    @default("pending") // "pending" | "approved" | "denied"
  reviewedById   Int?
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())

  user       User  @relation("ReportOwner", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("ReportReviewer", fields: [reviewedById], references: [id])

  @@index([status])
  @@index([userId])
}

model InviteToken {
  id          Int       @id @default(autoincrement())
  tokenHash   String    @unique // sha256 of the raw token; raw is shown once
  createdById Int
  role        String    @default("member") // role granted on signup
  expiresAt   DateTime
  maxUses     Int? // null = unlimited until expiry
  useCount    Int       @default(0)
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  createdBy User @relation(fields: [createdById], references: [id])
}

model AuthToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  type      String // "email_verification" | "password_reset"
  tokenHash String    @unique
  expiresAt DateTime // verification: 48h, reset: 1h
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model ChapterSettings {
  id              Int      @id @default(1) // singleton row
  chapterName     String   @default("Aberjona Chapter")
  yearlyHoursGoal Float    @default(10.0)
  updatedAt       DateTime @updatedAt
}

model IntegrationSettings {
  id                  Int      @id @default(1) // singleton row
  gmailUser           String?
  gmailAppPasswordEnc String? // AES-GCM ciphertext
  sheetsSpreadsheetId String?
  sheetsServiceEmail  String?
  sheetsPrivateKeyEnc String? // AES-GCM ciphertext
  updatedAt           DateTime @updatedAt
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  actorId    Int // officer's user id (no FK so it survives deletion)
  actorName  String // denormalized name snapshot
  action     String // e.g. "event.create", "roster.deactivate"
  summary    String // human-readable
  targetType String?
  targetId   Int?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model Session {
  id         String    @id @default(cuid())
  userId     Int
  tokenHash  String    @unique // sha256 of the random session secret in the cookie
  expiresAt  DateTime
  revokedAt  DateTime?
  userAgent  String?
  lastUsedAt DateTime  @default(now())
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
